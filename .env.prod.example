# Copy this to `.env` ON THE SERVER and fill in real values. NEVER commit .env.
# (.env is already gitignored.)

# --- PostgreSQL ---
POSTGRES_USER=parentcheck
POSTGRES_PASSWORD=CHANGE-ME-long-random-string
POSTGRES_DB=parentcheck

# --- Flask ---
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE-ME-long-random-string

# Optional: enables the AI/RAG path. Leave blank to run the rule engine only.
GEMINI_API_KEY=

# --- Public hostname for auto-HTTPS (no domain needed) ---
# After the EC2 is up and you know its public IP a.b.c.d, set (dots, not dashes):
#   SITE_ADDRESS=a.b.c.d.sslip.io
SITE_ADDRESS=
