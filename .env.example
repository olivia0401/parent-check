# 复制成 .env 并填好（.env 已被 .gitignore 忽略，不会提交）。
# 部署到 Render 时，在服务的 Environment 里设这些。

# 必填（生产）：用于签名 session cookie 的随机密钥。
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 数据层：PostgreSQL + pgvector 连接串。本地用 docker-compose 时无需改动。
DATABASE_URL=postgresql+psycopg2://parentcheck:parentcheck@localhost:5432/parentcheck

# Redis：分布式限流 / 缓存。本地用 docker-compose 时无需改动。
REDIS_URL=redis://localhost:6379/0

# 可选：地区版本。uk = 英国（159 / Action Fraud / GDPR，默认）；cn = 中国（96110 / 110 / PIPL）。
REGION=uk

# 可选：Gemini API key（免费额度）。设置后会启用 AI 二次分析 + RAG 知识库。
# 不设置的话，应用照常运行，只是没有这一步。
# 申请地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 可选：设为任意非空值才启用本地学习型模型（默认关闭，见 README「学习型模型」）。
# SEMANTIC_MODEL=1

# Render 会自动注入 RENDER=true，用来开启 Secure cookie；本地不用设。
